    },
    {
      "name": "🗂 Case Management",
      "item": [
        {
          "name": "List All Cases",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/cases/" }
        },
        {
          "name": "List OPEN Cases",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/cases/?status=OPEN" }
        },
        {
          "name": "Create Case",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/cases/",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transaction_id\": \"tx-demo-001\",\n  \"user_id\": \"user_0042\",\n  \"risk_score\": 7.8,\n  \"decision\": \"REVIEW\",\n  \"notes\": \"High-risk transaction flagged for analyst review\"\n}"
            }
          }
        },
        {
          "name": "Update Case (Analyst Decision)",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/api/v1/cases/CASE-XXXXXXXX",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"CLOSED\",\n  \"analyst_id\": \"analyst_001\",\n  \"decision_override\": \"BLOCK\",\n  \"notes\": \"Confirmed fraud after manual review. Card blocked.\"\n}"
            }
          }
        },
        {
          "name": "Case Stats",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/cases/stats/summary" }
        }
      ]
    },
    {
      "name": "🕸 Identity Graph",
      "item": [
        {
          "name": "Analyze Identity",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/api/v1/identity/analyze",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"user_0042\",\n  \"device_id\": \"dev_a1b2c3\",\n  \"ip_address\": \"203.0.113.42\",\n  \"action\": \"login\"\n}"
            }
          }
        },
        {
          "name": "Get User Identity Graph",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/identity/graph/user_0042" }
        },
        {
          "name": "Graph Stats",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/identity/stats" }
        }
      ]
    },
    {
      "name": "📊 Analytics",
      "item": [
        {
          "name": "Dashboard Data",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/analytics/dashboard" }
        },
        {
          "name": "Live Feed",
          "request": { "method": "GET", "url": "{{base_url}}/api/v1/analytics/live-feed?limit=20" }
